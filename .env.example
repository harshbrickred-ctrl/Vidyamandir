# Neon PostgreSQL (required)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Auth (required)
JWT_SECRET=change-this-to-a-long-random-string

# Admin account (created/updated on first login or db:seed)
ADMIN_EMAIL=admin@srtvidyamandir.com
ADMIN_PASSWORD=admin123

# Vercel Blob — gallery uploads (required for production gallery)
# Create at: Vercel Dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=

# SMTP — optional, for admission/contact email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
